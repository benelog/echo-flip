    "./lib/*": "./lib/*",
    "./theme": "./theme/index.js",
    "./theme/*": "./theme/*"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "downdoc": "1.1.0-stable",
    "pdf-lib": "^1.17.1",
    "puppeteer-core": "^25.3.0",
    "vitepress": "^1.6.3"
  }
}
