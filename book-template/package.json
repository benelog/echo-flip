{
  "name": "book-template",
  "version": "0.1.0",
  "description": "AsciiDoc 원고를 이북 뷰어 사이트와 PDF로 배포하는 책 템플릿 엔진",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
