# dev 환경(= Vercel Preview = 개발용 Supabase 프로젝트) 값의 전체 목록.
#
# 이 파일을 .env.dev 로 복사해 채우면 run_dev.sh / migrate_dev.sh 가 읽는다.
# direnv 를 쓴다면 .envrc(`dotenv .env.dev`)가 같은 파일을 셸에도 올려 준다.
# .env.dev 자체는 커밋되지 않는다(.gitignore).
#
# 로컬 모드(SQLite)는 이 파일이 필요 없다. ./run_local.sh 는 환경 변수 없이 뜬다.
# Vercel 대시보드에는 같은 이름으로 등록하되 스코프를 나눈다:
# Preview = 개발 프로젝트 값, Production = 운영 프로젝트 값.

# 서버용: Supabase → Connect → Transaction pooler (port 6543)
DATABASE_URL=postgresql://postgres.<dev-project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# 마이그레이션용: Session pooler (port 5432).
# advisory lock 이 세션에 묶이므로 6543 은 쓸 수 없고,
# direct 연결(db.<ref>.supabase.co)은 IPv6 전용이라 IPv4 환경에서는 붙지 않는다.
MIGRATE_DATABASE_URL=postgresql://postgres.<dev-project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# 웹 로그인(OAuth)과 토큰 검증. Supabase → Settings → API
SUPABASE_URL=https://<dev-project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon key 또는 publishable key>
# JWKS URL 은 SUPABASE_URL 에서 자동 유도된다. 직접 지정하려면:
# SUPABASE_JWKS_URL=https://<dev-project-ref>.supabase.co/auth/v1/.well-known/jwks.json

# 별도 오리진에서 API 를 호출할 때만 필요 (기본: 같은 오리진이라 불필요)
# ALLOWED_ORIGINS=
