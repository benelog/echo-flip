# dev 환경(= Vercel Preview = 개발용 Supabase 프로젝트) 값.
# 이 파일을 .env.dev 로 복사해 채우면 run_dev.sh / migrate_dev.sh 가 읽는다.
# .env.dev 는 .gitignore 로 커밋되지 않는다.

# 서버용: Supabase → Connect → Transaction pooler (port 6543)
DATABASE_URL=postgres://postgres.<dev-project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# 마이그레이션용: Session pooler 또는 Direct connection (port 5432)
MIGRATE_DATABASE_URL=postgres://postgres.<dev-project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# 웹 로그인(GitHub/Google)과 토큰 검증. Supabase → Settings → API
SUPABASE_URL=https://<dev-project-ref>.supabase.co
SUPABASE_ANON_KEY=<dev anon key>
